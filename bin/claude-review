#!/usr/bin/env bash
set -euo pipefail

# claude-review <PR#> -- launch an independent reviewer agent for a pull request.
#
# Opens a NEW tmux window (a new pane) in the CURRENT session, anchored to the
# current directory, running a fresh interactive claude (acceptEdits) that runs
# the /pr-review-automerge skill against the given PR. A new window means a new
# $TMUX_PANE, so claude-queue tracks the reviewer as its own entry and the
# author session is untouched -- "1 worktree = 1 tmux session" is preserved.
#
# The reviewer runs headless (claude -p): it executes /pr-review-automerge to
# completion and then exits, so tmux closes the window automatically (no
# remain-on-exit). pr-review-automerge no longer posts to the PR; it emits its
# final report to its session (stdout). Since the pane closes, we tee that
# stdout to a per-run log file under
# ${XDG_STATE_HOME:-$HOME/.local/state}/claude-review/<repo>/, so the record
# lives in a local log rather than on the PR or a left-open pane.
#
# The PR branch is already checked out in this worktree, so no second checkout
# (and no branch conflict) occurs; the author must hand off (stop editing this
# branch) once the reviewer is launched.
#
# Run from inside the tmux session of the worktree holding the PR branch.
#
# Usage: claude-review <PR-number>

usage() { echo "usage: claude-review <PR-number>" >&2; exit "${1:-1}"; }

[ $# -eq 1 ] || usage 1
case "$1" in -h|--help) usage 0 ;; esac
pr="$1"
if [[ ! "$pr" =~ ^[0-9]+$ ]]; then
  echo "claude-review: PR number must be numeric (got: $pr)" >&2
  exit 1
fi
if [ -z "${TMUX:-}" ]; then
  echo "claude-review: must be run inside a tmux session" >&2
  exit 1
fi

# Derive a durable log path so the review record survives the pane closing
# (the record no longer lives on the PR). Repo name from origin (network-free);
# branch is the checked-out PR branch, sanitized for use in a filename.
repo="$(basename -s .git "$(git remote get-url origin 2>/dev/null)" 2>/dev/null)"
[ -n "$repo" ] || repo="$(basename "$(git rev-parse --show-toplevel)")"
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
[ -n "$branch" ] && [ "$branch" != "HEAD" ] || branch="$(git rev-parse --short HEAD)"
branch="${branch//[^A-Za-z0-9._-]/-}"
logdir="${XDG_STATE_HOME:-$HOME/.local/state}/claude-review/${repo}"
mkdir -p "$logdir"
logfile="${logdir}/pr${pr}_${branch}_$(date +%Y%m%d-%H%M%S).log"

# tee the headless claude's stdout to the log file; the pane still closes when
# the pipe finishes (no remain-on-exit).
tmux new-window -c "$PWD" -n "review-pr${pr}" \
  bash -c "claude -p --permission-mode acceptEdits '/pr-review-automerge ${pr}' | tee -- '${logfile}'"
