#!/usr/bin/env bash
set -euo pipefail

# claude-worktree -- create a git worktree and (optionally) start an interactive
# claude inside a detached tmux session living in that worktree.
#
# Worktree path is a sibling of the repository named <toplevel>_<name> so the
# tmux window is easy to search. The underscore separator is tmux-safe (a dot
# would be misparsed as a window.pane delimiter in `tmux -t` targets). It anchors
# to the MAIN repository toplevel so names stay flat even when invoked from
# inside another worktree.
#
# When a prompt is given, claude is launched INSIDE a fresh detached tmux session
# (session name = worktree basename, matching the `gts` convention). Running it
# in its own pane means its $TMUX_PANE is that new pane -- so claude-queue tracks
# it correctly instead of colliding with the launching pane. Attach any time
# (`gts <session>` / `tmux attach -t <session>`); it is interactive, so it keeps
# running at the REPL after the initial prompt -- no `claude --resume` needed.
#
# Usage:
#   claude-worktree <name> [-b <branch>] [-- <prompt...>]
#
#   name           worktree label (suffix after the underscore); also the new
#                  branch name when -b is omitted
#   -b <branch>    branch to check out / create (default: <name>)
#   -- <prompt>    everything after `--` is the initial prompt; when given, an
#                  interactive claude (acceptEdits) is started in a detached tmux
#                  session in the worktree. Attach with the printed command.

usage() {
  # Print the first contiguous "# " comment block (the description), skipping the
  # shebang and the leading code lines, stripping the leading "# ".
  awk '/^#!/ {next} /^#/ {sub(/^# ?/, ""); print; seen=1; next} seen {exit}' "$0"
  exit "${1:-1}"
}

[ $# -ge 1 ] || usage 1

name=""
branch=""
prompt=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage 0 ;;
    -b) shift; [ $# -gt 0 ] || usage 1; branch="$1"; shift ;;
    --) shift; prompt="$*"; break ;;
    -*) echo "claude-worktree: unknown flag: $1" >&2; usage 1 ;;
    *)
      if [ -z "$name" ]; then name="$1"; shift
      else echo "claude-worktree: unexpected argument: $1" >&2; usage 1; fi ;;
  esac
done
[ -n "$name" ] || usage 1
# Reject tmux-unsafe characters in the worktree name: `.` and `:` are target
# delimiters in `tmux -t` (session:window.pane) and would break gts switching.
if [[ ! "$name" =~ ^[A-Za-z0-9_-]+$ ]]; then
  echo "claude-worktree: name must match [A-Za-z0-9_-]+ (got: $name)" >&2
  exit 1
fi
branch="${branch:-$name}"

# Anchor to the main worktree's toplevel (dir holding the common .git) so names
# never nest as <repo>_a_b when branching from inside a worktree.
common_git="$(git rev-parse --path-format=absolute --git-common-dir)"
main_top="$(dirname "$common_git")"
wt_path="${main_top}_${name}"

# Keep stdout clean (path only) so add-only mode is scriptable; git's checkout
# chatter goes to stderr.
if [ -d "$wt_path" ]; then
  echo "claude-worktree: worktree dir already exists, reusing: $wt_path" >&2
elif git show-ref --verify --quiet "refs/heads/${branch}"; then
  git worktree add "$wt_path" "$branch" >&2       # check out existing branch
else
  git worktree add -b "$branch" "$wt_path" >&2    # create new branch
fi

if [ -z "$prompt" ]; then
  echo "$wt_path"
  exit 0
fi

# Session name = worktree basename, matching the `gts` convention (it derives the
# session name from the dir basename), so gts won't create a duplicate.
session="$(basename "$wt_path")"

if tmux has-session -t "=$session" 2>/dev/null; then
  echo "claude-worktree: tmux session '$session' already exists; not launching a" >&2
  echo "  second claude. Attach with: gts $session" >&2
  exit 1
fi

# Start claude INSIDE a fresh detached tmux session in the worktree. Passing the
# prompt as a separate argv element keeps spaces/quotes intact (tmux preserves
# argv). Interactive (no -p) so it stays at the REPL after the first prompt.
tmux new-session -d -s "$session" -c "$wt_path" \
  claude --permission-mode acceptEdits "$prompt"

attach="gts $session"
[ -n "${TMUX:-}" ] || attach="tmux attach -t $session"

echo "worktree : $wt_path"
echo "branch   : $branch"
echo "session  : $session (detached; claude running with acceptEdits)"
echo "attach   : $attach"
