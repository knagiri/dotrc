#!/usr/bin/env bash
set -euo pipefail

# claude-worktree -- create a git worktree and (optionally) start an interactive
# claude inside a detached tmux session living in that worktree.
#
# Worktree path is a sibling of the repository named <toplevel>_<name> so the
# tmux window is easy to search. The underscore separator is tmux-safe (a dot
# would be misparsed as a window.pane delimiter in `tmux -t` targets). It anchors
# to the MAIN repository toplevel so names stay flat even when invoked from
# inside another worktree.
#
# When a prompt is given, claude is launched INSIDE a fresh detached tmux session
# (session name = worktree basename, matching the `gts` convention). Running it
# in its own pane means its $TMUX_PANE is that new pane -- so claude-queue tracks
# it correctly instead of colliding with the launching pane. Attach any time
# (`gts <session>` / `tmux attach -t <session>`); it is interactive, so it keeps
# running at the REPL after the initial prompt -- no `claude --resume` needed.
#
# When invoked from inside tmux, the launch is wrapped so that when claude exits
# the attached client is switched back to the pane it was called from (not just
# the origin session's currently-active pane). Nobody attached / origin pane gone
# both degrade to a silent no-op.
#
# A new worktree only checks out the branch: gitignored / uncommitted files of the
# invoking checkout do NOT propagate, and a delegated session cannot read outside
# its worktree without a permission prompt nobody is there to approve. `--seed`
# copies such files in, so the delegated prompt can reference them relatively.
#
# Usage:
#   claude-worktree [--self] [--model <alias>] [--seed <path>]... <name> [-b <branch>] [-- <prompt...>]
#
#   --self         anchor the worktree to the repo this script lives in (e.g.
#                  your dotfiles repo), not cwd. Use for repo-independent work.
#   --model <alias>
#                  pass --model <alias> to the launched claude (e.g. opus), so the
#                  caller picks the model for the role it is delegating. Omitted
#                  means claude keeps its inherited default model.
#   --seed <path>  copy <path> from cwd's checkout into the same relative path in
#                  the new worktree (repeatable). For files the delegated session
#                  needs but which the branch does not carry (gitignored specs,
#                  uncommitted notes). Must live inside cwd's checkout.
#   name           worktree label (suffix after the underscore); also the new
#                  branch name when -b is omitted
#   -b <branch>    branch to check out / create (default: <name>)
#   -- <prompt>    everything after `--` is the initial prompt; when given, an
#                  interactive claude (acceptEdits) is started in a detached tmux
#                  session in the worktree. Attach with the printed command.

usage() {
  # Print the first contiguous "# " comment block (the description), skipping the
  # shebang and the leading code lines, stripping the leading "# ".
  awk '/^#!/ {next} /^#/ {sub(/^# ?/, ""); print; seen=1; next} seen {exit}' "$0"
  exit "${1:-1}"
}

[ $# -ge 1 ] || usage 1

name=""
branch=""
prompt=""
self=0
model=""
seeds=()
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage 0 ;;
    -b) shift; [ $# -gt 0 ] || usage 1; branch="$1"; shift ;;
    --model) shift; [ $# -gt 0 ] || usage 1; model="$1"; shift ;;
    --seed) shift; [ $# -gt 0 ] || usage 1; seeds+=("$1"); shift ;;
    --self) self=1; shift ;;
    --) shift; prompt="$*"; break ;;
    -*) echo "claude-worktree: unknown flag: $1" >&2; usage 1 ;;
    *)
      if [ -z "$name" ]; then name="$1"; shift
      else echo "claude-worktree: unexpected argument: $1" >&2; usage 1; fi ;;
  esac
done
[ -n "$name" ] || usage 1
# Reject tmux-unsafe characters in the worktree name: `.` and `:` are target
# delimiters in `tmux -t` (session:window.pane) and would break gts switching.
if [[ ! "$name" =~ ^[A-Za-z0-9_-]+$ ]]; then
  echo "claude-worktree: name must match [A-Za-z0-9_-]+ (got: $name)" >&2
  exit 1
fi
branch="${branch:-$name}"

# By default anchor to cwd's repo; with --self anchor to the repo this script
# itself lives in (resolving any PATH symlink), so global harnesses land in the
# dotfiles repo even when cwd is an unrelated project.
repo_dir="."
if [ "$self" = 1 ]; then
  repo_dir="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
fi
common_git="$(git -C "$repo_dir" rev-parse --path-format=absolute --git-common-dir)"
main_top="$(dirname "$common_git")"
wt_path="${main_top}_${name}"

# Validate the seeds BEFORE creating the worktree: a missing or out-of-checkout
# seed means the delegated prompt would reference a file that never arrives, and
# the session stalls on its first read. Fail here rather than leave an orphan
# worktree behind. Sources are always resolved against cwd's checkout (the one
# holding the uncommitted files), even under --self.
seed_rels=()
if [ "${#seeds[@]}" -gt 0 ]; then
  seed_top="$(realpath -- "$(git rev-parse --show-toplevel)")"
  for seed in "${seeds[@]}"; do
    seed_abs="$(realpath -m -- "$seed")"
    if [ ! -e "$seed_abs" ]; then
      echo "claude-worktree: --seed path does not exist: $seed" >&2
      exit 1
    fi
    case "$seed_abs" in
      "$seed_top"/*) seed_rels+=("${seed_abs#"$seed_top"/}") ;;
      *) echo "claude-worktree: --seed path is outside $seed_top: $seed" >&2; exit 1 ;;
    esac
  done
fi

# Keep stdout clean (path only) so add-only mode is scriptable; git's checkout
# chatter goes to stderr.
if [ -d "$wt_path" ]; then
  echo "claude-worktree: worktree dir already exists, reusing: $wt_path" >&2
elif git -C "$repo_dir" show-ref --verify --quiet "refs/heads/${branch}"; then
  git -C "$repo_dir" worktree add "$wt_path" "$branch" >&2    # existing branch
else
  git -C "$repo_dir" worktree add -b "$branch" "$wt_path" >&2 # new branch
fi

# Seed the worktree. Copies stay untracked when the source is gitignored, so they
# inform the delegated session without ever landing in a commit.
for rel in ${seed_rels[@]+"${seed_rels[@]}"}; do
  dst="$wt_path/$rel"
  mkdir -p "$(dirname "$dst")"
  rm -rf -- "$dst"   # so a directory seed replaces rather than nests inside
  cp -a -- "$seed_top/$rel" "$dst"
  echo "claude-worktree: seeded $rel" >&2
done

if [ -z "$prompt" ]; then
  echo "$wt_path"
  exit 0
fi

# Session name = worktree basename, matching the `gts` convention (it derives the
# session name from the dir basename), so gts won't create a duplicate.
session="$(basename "$wt_path")"

if tmux has-session -t "=$session" 2>/dev/null; then
  echo "claude-worktree: tmux session '$session' already exists; not launching a" >&2
  echo "  second claude. Attach with: gts $session" >&2
  exit 1
fi

# Start claude INSIDE a fresh detached tmux session in the worktree. Passing the
# prompt as a separate argv element keeps spaces/quotes intact (tmux preserves
# argv). Interactive (no -p) so it stays at the REPL after the first prompt.
#
# When launched from inside tmux, wrap the launch in `bash -c` so that when
# claude exits we chain `switch-client -t <origin_pane>`, returning the attached
# client to the exact pane we were called from (session-level auto-return only
# lands on the origin session's active pane, not this one). The prompt and pane
# id ride in as positional args ($1/$2) -- never folded into the command string
# -- so quotes in the prompt can't break the chain. If nobody is attached, or
# the origin pane is already gone, switch-client is a graceful no-op (2>/dev/null)
# and the single-pane session just dies quietly when the inner bash exits.
#
# --model rides in as a positional arg too ($3, empty when unset) rather than
# being interpolated into the command string, for the same quoting reason. An
# empty model must not degrade to `--model ""` (claude would reject it), so each
# launch shape branches on it and omits the flag entirely when it is unset.
if [ -n "${TMUX:-}" ]; then
  tmux new-session -d -s "$session" -c "$wt_path" \
    bash -c 'if [ -n "$3" ]; then claude --permission-mode acceptEdits --model "$3" "$1"; else claude --permission-mode acceptEdits "$1"; fi; tmux switch-client -t "$2" 2>/dev/null' \
    bash "$prompt" "$TMUX_PANE" "$model"
elif [ -n "$model" ]; then
  tmux new-session -d -s "$session" -c "$wt_path" \
    claude --permission-mode acceptEdits --model "$model" "$prompt"
else
  tmux new-session -d -s "$session" -c "$wt_path" \
    claude --permission-mode acceptEdits "$prompt"
fi

attach="gts $session"
[ -n "${TMUX:-}" ] || attach="tmux attach -t $session"

echo "worktree : $wt_path"
echo "branch   : $branch"
echo "session  : $session (detached; claude running with acceptEdits)"
[ -z "$model" ] || echo "model    : $model"
echo "attach   : $attach"
